# ─────────────────────────────────────────────────────────────────
# FRONTEND — Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL="https://<ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# Clave pública de Stripe (pk_test_... o pk_live_...)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# URL base pública sin barra final
# Local: http://localhost:5173
# Producción: https://www.casarurallarasilla.com
VITE_APP_BASE_URL="https://www.casarurallarasilla.com"

# true = banner de pruebas visible + aviso antes de pagar
# false = modo producción real
VITE_BOOKING_TEST_MODE="true"

VITE_APP_NAME="La Rasilla"
VITE_APP_ENV="production"

# ─────────────────────────────────────────────────────────────────
# BACKEND — Supabase → Project Settings → Secrets (Edge Functions)
# ─────────────────────────────────────────────────────────────────
#
# STRIPE_SECRET_KEY        = sk_test_...   (nunca expongas la live aquí)
# STRIPE_WEBHOOK_SECRET    = whsec_...
# APP_URL                  = https://www.casarurallarasilla.com   (sin barra final)
# SUPABASE_SERVICE_ROLE_KEY = eyJ...
# RESEND_API_KEY           = re_...
#
# Nota: SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY están disponibles
# automáticamente en Edge Functions — no hace falta añadirlas manualmente.
